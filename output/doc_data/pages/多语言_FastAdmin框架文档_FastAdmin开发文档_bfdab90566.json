      "code": "__('My name is %s', \"FastAdmin\");",
      "language": "php"
    },
    {
      "code": "My name is FastAdmin",
      "language": "unknown"
    },
    {
      "code": "lang('My name is %s', [\"FastAdmin\"]);",
      "language": "php"
    },
    {
      "code": "__('This is %s,base on %s', 'FastAdmin', 'ThinkPHP5');",
      "language": "php"
    },
    {
      "code": "This is FastAdmin,base on ThinkPHP5",
      "language": "unknown"
    },
    {
      "code": "lang('This is %s,base on %s', ['FastAdmin', 'ThinkPHP5']);",
      "language": "php"
    },
