  "code_samples": [
    {
      "code": "<input id=\"c-title\" class=\"form-control\" data-rule=\"required;username\" name=\"row[title]\" type=\"text\" value=\"\" />",
      "language": "html"
    },
    {
      "code": "<input id=\"c-title\" class=\"form-control\" data-rule=\"required;diyname\" name=\"row[title]\" type=\"text\" value=\"\" />",
      "language": "html"
    },
    {
      "code": "$.validator.config({\n    rules: {\n        diyname: function (element) {\n            //如果直接返回文本，则表示失败的提示文字\n            //如果返回true表示成功\n            //如果返回Ajax对象则表示远程验证\n            if (element.value.toString().match(/^\\d+$/)) {\n                return '不能为纯数字';\n            }\n            if (!element.value.toString().match(/^[a-zA-Z0-9\\-_]+$/)) {\n                return '请输入字母或数字组合';\n            }\n            return $.ajax({\n                url: 'ajax/check',\n                type: 'POST',\n                data: {id: $(\"#c-title\").val(), name: element.name, value: element.value},\n                dataType: 'json'\n            });\n        }\n    }\n});",
      "language": "css"
    },
    {
      "code": "$result = \"验证结果\";\nif ($result) {\n    //失败\n    $this->error(\"用户名已经存在\");\n} else {\n    //成功\n    $this->success();\n}",
      "language": "php"
    },
    {
      "code": "<form novalidate>\n    ......\n</form>",
      "language": "html"
    }
  ],
