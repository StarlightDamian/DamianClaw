  "code_samples": [
    {
      "code": "chown www:www /var/www/yoursite -R\nchmod 555 /var/www/yoursite -R\nchmod u+w /var/www/yoursite/runtime -R\nchmod u+w /var/www/yoursite/public/uploads -R",
      "language": "sass"
    },
    {
      "code": "location ~ ^/(uploads|assets)/.*\\.(php|php5|jsp)$ {\n    deny all;\n}",
      "language": "unknown"
    },
    {
      "code": "RewriteEngine on RewriteCond % !^$\nRewriteRule uploads/(.*).(php)$ – [F]",
      "language": "unknown"
    },
    {
      "code": "<Directory \"/www/yoursite/public/uploads\">\n  <Files ~ \".php\">\n      Order allow,deny\n      Deny from all\n  </Files>\n</Directory>",
      "language": "jsx"
    },
    {
      "code": "location ~ .*\\.(txt|doc|pdf|rar|gz|zip|docx|exe|xlsx|ppt|pptx)$ {\n    add_header Content-Disposition attachment;\n}",
      "language": "unknown"
    },
    {
      "code": "<FilesMatch \"\\.(txt|doc|pdf|rar|gz|zip|docx|exe|xlsx|ppt|pptx)$\">\n   ForceType application/octet-stream\n   Header set Content-Disposition attachment\n</FilesMatch>",
      "language": "jsx"
    },
    {
      "code": "app_debug 设置为 false\napp_trace 设置为 false\ndeny_module_list 添加 admin，然后将public目录下的admin.php重命名，新版本FastAdmin已经自动禁用和重命名 \ncookie.httponly 设置为 true\ncookie.secure 设置为 true   //前提是你的网站仅提供https访问",
      "language": "unknown"
    },
    {
      "code": "application/common/controller/Frontend.php\napplication/common/controller/Api.php",
      "language": "unknown"
    },
    {
      "code": "$this->request->filter('trim,strip_tags,htmlspecialchars');",
      "language": "php"
    }
