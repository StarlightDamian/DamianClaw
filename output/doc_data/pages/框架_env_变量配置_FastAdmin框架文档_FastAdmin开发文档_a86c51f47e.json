      "level": "h2",
      "text": "启用 env",
      "id": "启用 env-2"
    },
    {
      "level": "h2",
      "text": "默认支持 的 env 键",
      "id": "默认支持 的 env 键-3"
    }
  ],
  "code_samples": [
    {
      "code": "cp .env.sample .env",
      "language": "bash"
    },
    {
      "code": "[app]\n;是否开启Debug调试\ndebug = false\n;是否开启Trace调试\ntrace = false\n\n[database]\nhostname = 数据库连接地址\ndatabase = 数据库名\nusername = 数据库连接用户名\npassword = 数据库连接密码\nhostport = 数据库连接端口\ncharset = 数据库连接编码\nprefix = 数据库表前缀\n;是否开启数据库调试\ndebug = false",
      "language": "json"
    }
  ],
