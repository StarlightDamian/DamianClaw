  "code_samples": [
    {
      "code": "<input type=\"text\" class=\"form-control\" data-role=\"autocomplete\" data-autocomplete-options='{\"url\":\"ajax/get_user_list\"}' />\n\n<input type=\"text\" class=\"form-control\" data-role=\"autocomplete\" data-autocomplete-options='{\"url\":\"ajax/get_user_list\", \"minChars\":2}' />",
      "language": "json"
    },
    {
      "code": "$(\"#test1\").data(\"autocomplete-options\", {\n    \"url\":\"ajax/get_user_list\", \n    \"minChars\":2,\n    \"onSelect\":function(){\n        //处理回调事件\n    },\n    \"params\": function(){\n        //动态传递参数\n        return {\"a\":1,\"b\":2};\n    }\n});",
      "language": "json"
    },
    {
      "code": "{\n    \"query\": \"iPhone\",\n    \"suggestions\": [\n        { \"value\": \"iPhone 11\", \"data\": \"iphone11\" },\n        { \"value\": \"iPhone 12\",       \"data\": \"iphone12\" },\n        { \"value\": \"iPhone XR\",        \"data\": \"iphonexr\" }\n    ]\n}",
      "language": "json"
    },
    {
      "code": "{\n    \"query\": \"iPhone\",\n    \"suggestions\": [\"iphone11\", \"iphone12\", \"iphone13\"]\n}",
      "language": "json"
    }
  ],
