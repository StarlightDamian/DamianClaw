      "id": "使用范例-4"
    }
  ],
  "code_samples": [
    {
      "code": "//一键生成test控制器的权限菜单\nphp think menu -c test\n//一键生成mydir/test控制器的权限菜单\nphp think menu -c mydir/test\n//删除test控制器生成的菜单\nphp think menu -c test -d 1\n//一键生成所有控制器的权限菜单，执行前请备份数据库。\nphp think menu -c all-controller",
      "language": "php"
    }
  ],
