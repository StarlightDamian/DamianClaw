      "id": "特别感谢-5"
    }
  ],
  "code_samples": [
    {
      "code": "<!--常规渲染-->\n<input type=\"text\" class=\"form-control\" data-role='tagsinput' />\n<!--设定默认值-->\n<input type=\"text\" class=\"form-control\" data-role='tagsinput' value=\"你好,世界\" />\n<!--自定义属性-->\n<input type=\"text\" class=\"form-control\" data-role='tagsinput' value=\"你好,世界\" data-tagsinput-options='{\"maxTags\":4, \"trimValue\":true}' />",
      "language": "html"
    },
    {
      "code": "$(\"#test1\").data(\"tagsinput-options\", {\n    \"maxTags\":4, \n    \"trimValue\":true,\n    \"onTagExists\":function(){\n        //处理回调事件\n    }\n});",
      "language": "json"
    },
    {
      "code": "<input type=\"text\" class=\"form-control\" data-role='tagsinput' data-tagsinput-options='{\"autocomplete\":{\"url\":\"/index/ajax/autocomplete\"}}' />",
      "language": "json"
    }
  ],
