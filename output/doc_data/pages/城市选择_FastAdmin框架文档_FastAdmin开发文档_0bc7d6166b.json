  "code_samples": [
    {
      "code": "<div class='control-relative'>\n    <input id=\"c-city\" class=\"form-control\" data-toggle=\"city-picker\" name=\"row[city]\" type=\"text\" value=\"\" />\n</div>",
      "language": "html"
    },
    {
      "code": "$(\"#city-picker\").on(\"cp:updated\", function() {\n  var citypicker = $(this).data(\"citypicker\");\n  var code = citypicker.getCode(\"district\") || citypicker.getCode(\"city\") || citypicker.getCode(\"province\");\n  $(\"#code\").val(code);\n});",
      "language": "gdscript"
    }
  ],
