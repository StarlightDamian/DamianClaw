  "code_samples": [
    {
      "code": "//一键安装FastAdmin\nphp think install\n//配置数据库连接地址为127.0.0.1\nphp think install -a 127.0.0.1\n//配置数据库用户名密码\nphp think install -u root -p 123456\n//配置数据库表名为dbname\nphp think install -d dbname\n//配置数据库表前缀为ff_\nphp think install -r ff_\n//强制重新安装FastAdmin\nphp think install -f 1",
